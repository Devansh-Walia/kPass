generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               Role      @default(MEMBER)
  orgId              String
  org                Organization @relation(fields: [orgId], references: [id])
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  apps               UserApp[]
  assignedApps       UserApp[] @relation("AssignedBy")
  transactions       Transaction[]
  contacts           Contact[]
  ownedDeals         Deal[]
  activities         Activity[]
  // Task Board
  createdBoards      Board[]
  assignedTasks      TaskCard[]       @relation("TaskAssignee")
  createdTasks       TaskCard[]       @relation("TaskCreator")
  // Student Tracker
  createdStudents    Student[]
  markedAttendance   StudentAttendance[] @relation("AttendanceMarker")
  // Needs Registry
  requestedNeeds     NeedRequest[]    @relation("NeedRequester")
  approvedNeeds      NeedRequest[]    @relation("NeedApprover")
  // HR
  createdEmployees   Employee[]
  employee           Employee?        @relation("EmployeeUser")
  markedStaffAtt     StaffAttendance[] @relation("StaffAttMarker")
  reviewedLeaves     LeaveRequest[]   @relation("LeaveReviewer")
  // Ideation
  createdIdeas       Idea[]
  // Content Calendar
  createdPosts       ContentPost[]
  // Events
  createdEvents      Event[]
  volunteeredEvents  EventVolunteer[]
  // Workshops
  createdWorkshops   Workshop[]
  // Donors
  createdDonors      Donor[]
  createdDonations   Donation[]
  // Departments
  departments        UserDepartment[]
}

enum AppType {
  FINANCE
  CRM
  MARKETING
  IDEATION
  TASK_BOARD
  STUDENT_TRACKER
  NEEDS_REGISTRY
  HR
  ATTENDANCE
  CONTENT_CALENDAR
  EVENT_MANAGER
  WORKSHOP
  DONOR_MGMT
  CUSTOM
}

model App {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  type        AppType
  route       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  users       UserApp[]
  departments DepartmentApp[]
}

model Department {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  users       UserDepartment[]
  defaultApps DepartmentApp[]
  createdAt   DateTime         @default(now())
}

model DepartmentApp {
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  appId        String
  app          App        @relation(fields: [appId], references: [id], onDelete: Cascade)
  @@id([departmentId, appId])
}

model UserDepartment {
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
  @@id([userId, departmentId])
}

model UserApp {
  userId       String
  appId        String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())
  assignedById String
  assignedBy   User     @relation("AssignedBy", fields: [assignedById], references: [id])
  source       String   @default("manual")

  @@id([userId, appId])
}

enum TransactionType {
  INCOME
  EXPENSE
}

model FinanceCategory {
  id           String          @id @default(uuid())
  name         String
  type         TransactionType
  transactions Transaction[]
}

model Transaction {
  id          String          @id @default(uuid())
  amount      Float
  type        TransactionType
  categoryId  String
  category    FinanceCategory @relation(fields: [categoryId], references: [id])
  description String?
  date        DateTime
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
}

model Contact {
  id          String     @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  tags        String[]
  notes       String?
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  deals       Deal[]
  activities  Activity[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum DealStage {
  LEAD
  CONTACTED
  PROPOSAL
  CLOSED
}

model Deal {
  id        String    @id @default(uuid())
  title     String
  value     Float
  stage     DealStage @default(LEAD)
  contactId String
  contact   Contact   @relation(fields: [contactId], references: [id])
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum ActivityType {
  CALL
  EMAIL
  NOTE
  MEETING
}

model Activity {
  id          String       @id @default(uuid())
  contactId   String
  contact     Contact      @relation(fields: [contactId], references: [id])
  type        ActivityType
  content     String
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
}

// ─── Task Board ───────────────────────────────────────

model Board {
  id          String     @id @default(uuid())
  name        String
  description String?
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  tasks       TaskCard[]
  createdAt   DateTime   @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model TaskCard {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  boardId     String
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User         @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── Student Tracker ──────────────────────────────────

model Student {
  id            String              @id @default(uuid())
  name          String
  age           Int
  guardianName  String
  guardianPhone String?
  batch         String
  enrollmentDate DateTime
  isActive      Boolean             @default(true)
  createdById   String
  createdBy     User                @relation(fields: [createdById], references: [id])
  attendance    StudentAttendance[]
  workshopParticipations WorkshopParticipant[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model StudentAttendance {
  id         String           @id @default(uuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime
  status     AttendanceStatus
  markedById String
  markedBy   User             @relation("AttendanceMarker", fields: [markedById], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([studentId, date])
}

// ─── Needs Registry ───────────────────────────────────

enum NeedCategory {
  SANITATION
  HEALTH
  SUPPLIES
  OTHER
}

enum NeedStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
}

model NeedRequest {
  id            String       @id @default(uuid())
  childName     String
  category      NeedCategory
  description   String
  status        NeedStatus   @default(PENDING)
  requestedById String
  requestedBy   User         @relation("NeedRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?        @relation("NeedApprover", fields: [approvedById], references: [id])
  fulfilledAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─── HR — People Directory ────────────────────────────

model Employee {
  id          String            @id @default(uuid())
  name        String
  email       String?
  phone       String?
  department  String
  designation String
  joinDate    DateTime
  isActive    Boolean           @default(true)
  userId      String?           @unique
  user        User?             @relation("EmployeeUser", fields: [userId], references: [id])
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  attendance  StaffAttendance[]
  leaves      LeaveRequest[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─── HR — Attendance ──────────────────────────────────

enum StaffAttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

model StaffAttendance {
  id         String                @id @default(uuid())
  employeeId String
  employee   Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     StaffAttendanceStatus
  markedById String
  markedBy   User                  @relation("StaffAttMarker", fields: [markedById], references: [id])
  createdAt  DateTime              @default(now())

  @@unique([employeeId, date])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id           String      @id @default(uuid())
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?       @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// ─── Ideation ─────────────────────────────────────────

enum IdeaStage {
  IDEA
  APPROVED
  IN_PROGRESS
  DONE
}

model Idea {
  id          String    @id @default(uuid())
  title       String
  description String
  stage       IdeaStage @default(IDEA)
  votes       Int       @default(0)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Content Calendar ─────────────────────────────────

enum Platform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  OTHER
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

model ContentPost {
  id            String     @id @default(uuid())
  title         String
  content       String?
  platform      Platform
  scheduledDate DateTime
  status        PostStatus @default(DRAFT)
  createdById   String
  createdBy     User       @relation(fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ─── Event Manager ────────────────────────────────────

enum EventStatus {
  PLANNING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Event {
  id          String           @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  status      EventStatus      @default(PLANNING)
  budget      Float?
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
  volunteers  EventVolunteer[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model EventVolunteer {
  id      String   @id @default(uuid())
  eventId String
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  role    String?
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ─── Workshop Tracker ─────────────────────────────────

model Workshop {
  id              String                @id @default(uuid())
  title           String
  description     String?
  date            DateTime
  instructor      String
  materialsNeeded String?
  maxParticipants Int?
  createdById     String
  createdBy       User                  @relation(fields: [createdById], references: [id])
  participants    WorkshopParticipant[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model WorkshopParticipant {
  id         String   @id @default(uuid())
  workshopId String
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  studentId  String?
  student    Student? @relation(fields: [studentId], references: [id])
  studentName String
  attended   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([workshopId, studentName])
}

// ─── Donor / Sponsor Management ───────────────────────

enum DonorType {
  INDIVIDUAL
  CORPORATE
}

model Donor {
  id          String     @id @default(uuid())
  name        String
  email       String?
  phone       String?
  type        DonorType
  notes       String?
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  donations   Donation[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Donation {
  id          String   @id @default(uuid())
  donorId     String
  donor       Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  amount      Float
  date        DateTime
  purpose     String?
  receiptNo   String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}
